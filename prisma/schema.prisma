generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// USUARIOS Y AUTENTICACIÓN
// ==========================================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(EMPLEADO)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  EMPLEADO
}

// ==========================================
// ENTIDADES BASE
// ==========================================
model Proveedor {
  id              String   @id @default(cuid())
  razonSocial     String
  cuit            String   @unique
  condicionIva    CondicionIva
  direccion       String?
  telefono        String?
  email           String?
  observaciones   String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  facturasRecibidas  FacturaRecibida[]
  liquidacionesRecibidas LiquidacionRecibida[]
  chequesEmitidos    ChequeEmitido[]
  chequesRecibidosDestino ChequeRecibido[] @relation("ProveedorDestinoChequeRecibido")
  cuentaCorriente    CuentaCorriente[]

  @@map("proveedores")
}

model Cliente {
  id              String   @id @default(cuid())
  razonSocial     String
  cuit            String   @unique
  condicionIva    CondicionIva
  direccion       String?
  telefono        String?
  email           String?
  observaciones   String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  facturasEmitidas    FacturaEmitida[]
  liquidacionesEmitidas LiquidacionEmitida[]
  chequesRecibidos    ChequeRecibido[]

  @@map("clientes")
}

enum CondicionIva {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTISTA
  EXENTO
  CONSUMIDOR_FINAL
  NO_CATEGORIZADO
}

// ==========================================
// FACTURAS EMITIDAS (IVA VENTA)
// ==========================================
model FacturaEmitida {
  id              String        @id @default(cuid())
  numero          Int           @default(autoincrement())
  tipoComprobante TipoComprobante
  fecha           DateTime
  clienteId       String
  cliente         Cliente       @relation(fields: [clienteId], references: [id])
  descripcion     String?
  netoGravado     Decimal       @db.Decimal(12, 2)
  netoNoGravado   Decimal       @default(0) @db.Decimal(12, 2)
  netoExento      Decimal       @default(0) @db.Decimal(12, 2)
  alicuotaIva     Decimal       @db.Decimal(5, 2)
  montoIva        Decimal       @db.Decimal(12, 2)
  percepcionIva   Decimal       @default(0) @db.Decimal(12, 2)
  percepcionIIBB  Decimal       @default(0) @db.Decimal(12, 2)
  otrosImpuestos  Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  observaciones   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("facturas_emitidas")
}

// ==========================================
// FACTURAS RECIBIDAS (IVA COMPRA)
// ==========================================
model FacturaRecibida {
  id              String        @id @default(cuid())
  numero          Int           @default(autoincrement())
  tipoComprobante TipoComprobante
  fecha           DateTime
  proveedorId     String
  proveedor       Proveedor     @relation(fields: [proveedorId], references: [id])
  descripcion     String?
  netoGravado     Decimal       @db.Decimal(12, 2)
  netoNoGravado   Decimal       @default(0) @db.Decimal(12, 2)
  netoExento      Decimal       @default(0) @db.Decimal(12, 2)
  alicuotaIva     Decimal       @db.Decimal(5, 2)
  montoIva        Decimal       @db.Decimal(12, 2)
  percepcionIva   Decimal       @default(0) @db.Decimal(12, 2)
  percepcionIIBB  Decimal       @default(0) @db.Decimal(12, 2)
  otrosImpuestos  Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  observaciones   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("facturas_recibidas")
}

enum TipoComprobante {
  FACTURA_A
  FACTURA_B
  FACTURA_C
  NOTA_CREDITO_A
  NOTA_CREDITO_B
  NOTA_CREDITO_C
  NOTA_DEBITO_A
  NOTA_DEBITO_B
  NOTA_DEBITO_C
  RECIBO
}

// ==========================================
// LIQUIDACIONES EMITIDAS (IVA VENTA)
// ==========================================
model LiquidacionEmitida {
  id              String   @id @default(cuid())
  numero          Int
  fecha           DateTime
  clienteId       String
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
  concepto        String
  descripcion     String?
  netoGravado     Decimal  @db.Decimal(12, 2)
  alicuotaIva     Decimal  @db.Decimal(5, 2)
  montoIva        Decimal  @db.Decimal(12, 2)
  retenciones     Decimal  @default(0) @db.Decimal(12, 2)
  otrosConceptos  Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  observaciones   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("liquidaciones_emitidas")
}

// ==========================================
// LIQUIDACIONES RECIBIDAS (IVA COMPRA)
// ==========================================
model LiquidacionRecibida {
  id              String    @id @default(cuid())
  numero          Int
  fecha           DateTime
  proveedorId     String
  proveedor       Proveedor @relation(fields: [proveedorId], references: [id])
  concepto        String
  descripcion     String?
  netoGravado     Decimal   @db.Decimal(12, 2)
  alicuotaIva     Decimal   @db.Decimal(5, 2)
  montoIva        Decimal   @db.Decimal(12, 2)
  retenciones     Decimal   @default(0) @db.Decimal(12, 2)
  otrosConceptos  Decimal   @default(0) @db.Decimal(12, 2)
  total           Decimal   @db.Decimal(12, 2)
  observaciones   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("liquidaciones_recibidas")
}

// ==========================================
// BANCOS
// ==========================================
model Banco {
  id              String   @id @default(cuid())
  nombre          String
  sucursal        String?
  numeroCuenta    String
  cbu             String?  @unique
  alias           String?
  tipoCuenta      TipoCuenta
  saldoInicial    Decimal  @default(0) @db.Decimal(12, 2)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  chequesEmitidos  ChequeEmitido[]
  chequesRecibidos ChequeRecibido[] @relation("BancoOrigenChequeRecibido")
  chequesRecibidosDestino ChequeRecibido[] @relation("BancoDestinoChequeRecibido")
  movimientos      MovimientoBanco[]

  @@map("bancos")
}

enum TipoCuenta {
  CUENTA_CORRIENTE
  CAJA_AHORRO
}

// ==========================================
// CHEQUES EMITIDOS
// ==========================================
model ChequeEmitido {
  id              String        @id @default(cuid())
  bancoId         String
  banco           Banco         @relation(fields: [bancoId], references: [id])
  numeroCheque    String
  formato         FormatoCheque  @default(FISICO)
  fecha           DateTime
  fechaCobro      DateTime
  proveedorId     String
  proveedor       Proveedor     @relation(fields: [proveedorId], references: [id])
  concepto        String?
  monto           Decimal       @db.Decimal(12, 2)
  estado          EstadoCheque  @default(PENDIENTE)
  observaciones   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("cheques_emitidos")
}

// ==========================================
// CHEQUES RECIBIDOS
// ==========================================
model ChequeRecibido {
  id              String        @id @default(cuid())
  bancoOrigenId   String?
  bancoOrigen     Banco?        @relation("BancoOrigenChequeRecibido", fields: [bancoOrigenId], references: [id])
  numeroCheque    String
  formato         FormatoCheque  @default(FISICO)
  bancoEmisor     String
  fecha           DateTime
  fechaCobro      DateTime
  clienteId       String
  cliente         Cliente       @relation(fields: [clienteId], references: [id])
  concepto        String?
  monto           Decimal       @db.Decimal(12, 2)
  estado          EstadoCheque  @default(PENDIENTE)
  destinoTipo     DestinoChequeRecibido?
  bancoDestinoId  String?
  bancoDestino    Banco?        @relation("BancoDestinoChequeRecibido", fields: [bancoDestinoId], references: [id])
  proveedorDestinoId String?
  proveedorDestino Proveedor?   @relation("ProveedorDestinoChequeRecibido", fields: [proveedorDestinoId], references: [id])
  destinoDetalle  String?
  observaciones   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("cheques_recibidos")
}

enum EstadoCheque {
  PENDIENTE
  COBRADO
  DEPOSITADO
  RECHAZADO
  ANULADO
  ENDOSADO
}

enum FormatoCheque {
  FISICO
  E_CHECK
}

enum DestinoChequeRecibido {
  DEPOSITO
  VENTA
  PROVEEDOR
  CARTERA
}

// ==========================================
// MOVIMIENTOS BANCARIOS
// ==========================================
model MovimientoBanco {
  id          String          @id @default(cuid())
  bancoId     String
  banco       Banco           @relation(fields: [bancoId], references: [id])
  fecha       DateTime
  tipo        TipoMovimiento
  concepto    String
  monto       Decimal         @db.Decimal(12, 2)
  referencia  String?
  createdAt   DateTime        @default(now())

  @@map("movimientos_banco")
}

enum TipoMovimiento {
  DEBITO
  CREDITO
}

// ==========================================
// CUENTAS CORRIENTES (PROVEEDORES)
// ==========================================
model CuentaCorriente {
  id            String   @id @default(cuid())
  proveedorId   String
  proveedor     Proveedor @relation(fields: [proveedorId], references: [id])
  fecha         DateTime
  concepto      String
  tipo          TipoMovimientoCC
  debe          Decimal  @default(0) @db.Decimal(12, 2)
  haber         Decimal  @default(0) @db.Decimal(12, 2)
  saldo         Decimal  @db.Decimal(12, 2)
  referencia    String?
  observaciones String?
  createdAt     DateTime @default(now())

  @@map("cuentas_corrientes")
}

enum TipoMovimientoCC {
  FACTURA
  PAGO
  NOTA_CREDITO
  NOTA_DEBITO
  AJUSTE
}

// ==========================================
// CAMPOS DE PRODUCCIÓN
// ==========================================
model Campo {
  id            String       @id @default(cuid())
  nombre        String
  ubicacion     String?
  latitud       Decimal?     @db.Decimal(10, 7)
  longitud      Decimal?     @db.Decimal(10, 7)
  hectareas     Decimal      @db.Decimal(10, 2)
  tipo          TipoCampo
  propietario   String?
  costoAlquiler Decimal?     @db.Decimal(12, 2)
  observaciones String?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  producciones  Produccion[]
  cartasPorte   CartaPorte[]

  @@map("campos")
}

enum TipoCampo {
  PROPIO
  ALQUILADO
}

model Produccion {
  id            String    @id @default(cuid())
  campoId       String
  campo         Campo     @relation(fields: [campoId], references: [id])
  cultivo       Cultivo
  campania      String
  hectareas     Decimal   @db.Decimal(10, 2)
  kgCosechados  Decimal   @db.Decimal(12, 2)
  rindeKgHa     Decimal   @db.Decimal(10, 2)
  fechaCosecha  DateTime?
  observaciones String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("producciones")
}

enum Cultivo {
  SOJA
  MAIZ
  TRIGO
  SORGO
  GIRASOL
  CEBADA
  OTRO
}

// ==========================================
// CARTAS DE PORTE (CONTROL INTERNO)
// ==========================================
model CartaPorte {
  id               String       @id @default(cuid())
  numero           Int          @default(autoincrement())
  fecha            DateTime
  campoOrigenId    String?
  campoOrigen      Campo?       @relation(fields: [campoOrigenId], references: [id])
  localidadOrigen  String?
  destino          String
  localidadDestino String?
  producto         Cultivo
  cosecha          String?
  pesoBrutoKg      Decimal      @db.Decimal(12, 2)
  pesoTaraKg       Decimal      @db.Decimal(12, 2)
  pesoNetoKg       Decimal      @db.Decimal(12, 2)
  transportista    String?
  patenteCamion    String?
  patenteAcoplado  String?
  chofer           String?
  ctg              String?
  estado           EstadoCarta  @default(EN_TRANSITO)
  observaciones    String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("cartas_porte")
}

enum EstadoCarta {
  PENDIENTE
  EN_TRANSITO
  DESCARGADA
  CONFIRMADA
  ANULADA
}
